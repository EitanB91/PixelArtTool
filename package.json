{
  "name": "pixel-art-tool",
  "version": "0.1.0",
  "description": "AI-assisted pixel art tool — sprite generation pipeline for game development",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "test": "jest --testPathPattern=tests/",
    "convert": "node tools/png2sprite.js",
    "icon": "node tools/generate-icon.js"
  },
  "keywords": [
    "pixel-art",
    "sprite",
    "game-dev",
    "ai",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0",
    "jest": "^29.0.0"
  },
  "dependencies": {
    "pngjs": "^7.0.0"
  },
  "build": {
    "appId": "com.gamedev.pixel-art-tool",
    "productName": "Pixel Art Tool",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "tools/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pixel Art Tool"
    }
  }
}
