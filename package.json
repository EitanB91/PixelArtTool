{
  "name": "pixel-art-tool",
  "version": "0.1.0",
  "description": "AI-assisted pixel art tool — sprite generation pipeline for game development",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "test": "jest --testPathPattern=tests/",
    "convert": "node tools/png2sprite.js"
  },
  "keywords": ["pixel-art", "sprite", "game-dev", "ai", "electron"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "jest": "^29.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "pngjs": "^7.0.0"
  },
  "build": {
    "appId": "com.gamedev.pixel-art-tool",
    "productName": "Pixel Art Tool",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "tools/**/*"
    ]
  }
}
